# tcmotor.template
#
# Template for a single TwinCAT motor record instance.
#
# Macros:
#   PREFIX   - PV prefix (e.g. TST:MOTION:)
#   M        - Motor name (e.g. M1)
#   DESC     - Motor description
#   EGU      - Engineering units (e.g. mm)
#   PREC     - Display precision (e.g. 3)

record(tcmotor, "$(PREFIX)$(M)") {
    field(DESC,  "$(DESC=TwinCAT Motor)")
    field(EGU,   "$(EGU=mm)")
    field(PREC,  "$(PREC=3)")
    field(PINI,  "YES")
    field(HLSV, "MAJOR")
    field(LLSV, "MAJOR")
    field(LSV,  "MAJOR")
    field(IDLY,  "$(IDLY=5)")

    field(INP_RBV,  "$(PREFIX)$(M):fActPosition_RBV CP MS")
    field(INP_EGU,  "$(PREFIX)$(M):NC:Eu:Val_RBV CP MS")
    field(INP_DMOV, "$(PREFIX)$(M):bDone_RBV CP MS")
    field(INP_MOVN, "$(PREFIX)$(M):bMoving_RBV CP MS")
    field(INP_HLS,  "$(PREFIX)$(M):bForwardEnabled_RBV CP MS")
    field(INP_LLS,  "$(PREFIX)$(M):bBackwardEnabled_RBV CP MS")
    field(INP_ATHM, "$(PREFIX)$(M):bHomeSensorEnabled_RBV CP MS")
    field(INP_NDIR, "$(PREFIX)$(M):bNegativeDirection_RBV CP MS")
    field(INP_PDIR, "$(PREFIX)$(M):bPositiveDirection_RBV CP MS")
    field(INP_ERR,  "$(PREFIX)$(M):bError_RBV CP MS")
    field(INP_HMNG, "$(PREFIX)$(M):bHoming_RBV CP MS")
    field(INP_OFF,  "$(PREFIX)$(M):NC:PosBias:Val_RBV CP MS")
    field(INP_HLM,  "$(PREFIX)$(M):NC:MaxPos:Val_RBV CP MS")
    field(INP_LLM,  "$(PREFIX)$(M):NC:MinPos:Val_RBV CP MS")
    field(INP_HOMED,"$(PREFIX)$(M):bHomed_RBV CP MS")
    field(INP_HPOS, "$(PREFIX)$(M):fHomePosition_RBV CP MS")
    # Read once in process() on first PINI scan to seed output field
    # initial values from the PLC.
    field(RBK_VAL,  "$(PREFIX)$(M):fPosition_RBV")
    field(RBK_VELO, "$(PREFIX)$(M):fVelocity_RBV")
    field(RBK_VBAS, "$(PREFIX)$(M):NC:RefVel:Val_RBV")
    field(RBK_VMAX, "$(PREFIX)$(M):NC:MaxVel:Val_RBV")
    field(RBK_ACCS, "$(PREFIX)$(M):fAcceleration_RBV")
    field(RBK_CNEN, "$(PREFIX)$(M):bUserEnable_RBV")
    field(RBK_HLM,  "$(PREFIX)$(M):NC:MaxPos:Val_RBV")
    field(RBK_LLM,  "$(PREFIX)$(M):NC:MinPos:Val_RBV")
    field(RBK_BDST, "$(PREFIX)$(M):NC:Backlash:Val_RBV")
    field(RBK_OFF,  "$(PREFIX)$(M):NC:PosBias:Val_RBV")
    field(OUT_VAL,  "$(PREFIX)$(M):fPosition PP")
    field(OUT_STOP, "$(PREFIX)$(M):bHalt PP")
    field(OUT_HOMF, "$(PREFIX)$(M):bHomeCmd PP")
    field(OUT_HMOD, "$(PREFIX)$(M):eHomeMode PP")
    field(OUT_MCMD, "$(PREFIX)$(M):bMoveCmd PP")
    field(OUT_TWF,  "$(PREFIX)$(M):bJogFwdCmd PP")
    field(OUT_TIF,  "$(PREFIX)$(M):NC:JogIncFwd:Goal PP")
    field(OUT_TWR,  "$(PREFIX)$(M):bJogBwdCmd PP")
    field(OUT_TIR,  "$(PREFIX)$(M):NC:JogIncBwd:Goal PP")
    field(OUT_VELO, "$(PREFIX)$(M):fVelocity PP")
    field(OUT_VBAS, "$(PREFIX)$(M):NC:RefVel:Goal PP")
    field(OUT_VMAX, "$(PREFIX)$(M):NC:MaxVel:Goal PP")
    field(OUT_ACCS, "$(PREFIX)$(M):fAcceleration PP")
    field(OUT_DECS, "$(PREFIX)$(M):fDeceleration PP")
    field(OUT_CNEN, "$(PREFIX)$(M):bUserEnable PP")
    field(OUT_HLM,  "$(PREFIX)$(M):NC:MaxPos:Goal PP")
    field(OUT_LLM,  "$(PREFIX)$(M):NC:MinPos:Goal PP")
    field(OUT_BDST, "$(PREFIX)$(M):NC:Backlash:Goal PP")
    field(OUT_OFF,  "$(PREFIX)$(M):NC:PosBias:Goal PP MS")
}


# Command records that trigger the move with StreamDevice
record(bo, "$(PREFIX)$(M):MoveCmd")
{
    field(DESC, "Trigger pre-configured absolute move")
    field(DTYP, "stream")
    field(FLNK, "$(PREFIX)$(M):ResetCmd")
    field(OUT,  "@tcmotor.proto move_cmd($(ADSPORT), $(ADSPATH), $(PREFIX), $(M), $(PREC=3)) $(PORT)")
}

record(bo, "$(PREFIX)$(M):HomeCmd")
{
    field(DESC, "Trigger pre-configured home move")
    field(DTYP, "stream")
    field(FLNK, "$(PREFIX)$(M):ResetCmd")
    field(OUT,  "@tcmotor.proto home_cmd($(ADSPORT), $(ADSPATH), $(PREFIX), $(M), $(PREC=3)) $(PORT)")
}

record(seq, "$(PREFIX)$(M):ResetCmd")
{
   field(DESC, "auto reset previous cmd")
   field(SCAN, "Passive")
   field(DO1, "0")
   field(DO2, "0")
   field(LNK1, "$(PREFIX)$(M):MoveCmd")
   field(LNK2, "$(PREFIX)$(M):HomeCmd")
   field(PINI, "YES")
}

