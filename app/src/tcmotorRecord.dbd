# tcmotorRecord.dbd
#
# Record type definition for the TwinCAT Motor (tcmotor) record.
#
# Provides motor record field naming convention (.VAL, .RBV, .DMOV etc.)
# for TwinCAT ADS-based motors with no internal motion logic.
#
# Link field naming convention:
#   INP_*  — input link fields (CP links from PLC status PVs)
#   OUT_*  — output link fields (PP links to PLC command PVs)
#   RBK_*  — init-only readback links (CA from PLC _RBV counterparts,
#             read once at PINI to seed initial output field values)
#
# Computed fields (derived in process, not directly linked):
#   TDIR   — computed from INP_NDIR + INP_PDIR
#   MSTA   — computed from all status bools (motor record bit convention)
#   SPMG   — Stop/Pause/Move/Go state machine owned by tcmotor
#             (replaces FB_MotionSPMG in the PLC)

menu(tcmotorSPMG) {
    choice(tcmotorSPMG_Stop,  "Stop")
    choice(tcmotorSPMG_Pause, "Pause")
    choice(tcmotorSPMG_Move,  "Move")
    choice(tcmotorSPMG_Go,    "Go")
}

recordtype(tcmotor) {

    # -----------------------------------------------------------------------
    # Standard fields common to all records
    # -----------------------------------------------------------------------
    include "dbCommon.dbd"

    # -----------------------------------------------------------------------
    # Display / engineering fields (local, no links)
    # -----------------------------------------------------------------------
    field(EGU, DBF_STRING) {
        prompt("Engineering Units")
        promptgroup("80 - Display")
        special(SPC_MOD)
        interest(1)
        size(16)
    }
    field(PREC, DBF_SHORT) {
        prompt("Display Precision")
        promptgroup("80 - Display")
        interest(1)
    }
    field(HOPR, DBF_DOUBLE) {
        prompt("High Operating Range")
        promptgroup("80 - Display")
        interest(1)
    }
    field(LOPR, DBF_DOUBLE) {
        prompt("Low Operating Range")
        promptgroup("80 - Display")
        interest(1)
    }
    field(DRVH, DBF_DOUBLE) {
        prompt("Drive High Limit")
        promptgroup("30 - Action")
        interest(1)
    }
    field(DRVL, DBF_DOUBLE) {
        prompt("Drive Low Limit")
        promptgroup("30 - Action")
        interest(1)
    }

    # -----------------------------------------------------------------------
    # Input fields — direct status from PLC (INP_* links, CP)
    # -----------------------------------------------------------------------

    field(INP_RBV, DBF_INLINK) {
        prompt("Readback Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(RBV, DBF_DOUBLE) {
        prompt("Readback Value")
        special(SPC_NOMOD)
        interest(1)
    }

    field(INP_DMOV, DBF_INLINK) {
        prompt("Done Moving Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(DMOV, DBF_SHORT) {
        prompt("Done Moving")
        special(SPC_NOMOD)
        interest(1)
    }

    field(INP_MOVN, DBF_INLINK) {
        prompt("Moving Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(MOVN, DBF_SHORT) {
        prompt("Motor Is Moving")
        special(SPC_NOMOD)
        interest(1)
    }

    field(INP_HLS, DBF_INLINK) {
        prompt("High Limit Switch Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(HLS, DBF_SHORT) {
        prompt("At High Limit Switch")
        special(SPC_NOMOD)
        interest(1)
    }

    field(INP_LLS, DBF_INLINK) {
        prompt("Low Limit Switch Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(LLS, DBF_SHORT) {
        prompt("At Low Limit Switch")
        special(SPC_NOMOD)
        interest(1)
    }

    field(INP_ATHM, DBF_INLINK) {
        prompt("At Home Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(ATHM, DBF_SHORT) {
        prompt("At HOME")
        special(SPC_NOMOD)
        interest(1)
    }

    # Direction of travel — computed from INP_NDIR and INP_PDIR
    # 0 = negative, 1 = positive, unchanged when stopped
    field(INP_NDIR, DBF_INLINK) {
        prompt("Negative Direction Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(INP_PDIR, DBF_INLINK) {
        prompt("Positive Direction Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(NDIR, DBF_SHORT) {
        prompt("Moving In Negative Direction")
        special(SPC_NOMOD)
        interest(2)
    }
    field(PDIR, DBF_SHORT) {
        prompt("Moving In Positive Direction")
        special(SPC_NOMOD)
        interest(2)
    }
    field(TDIR, DBF_SHORT) {
        prompt("Direction of Travel (0=Neg 1=Pos)")
        special(SPC_NOMOD)
        interest(1)
    }

    # Error status — used for MSTA computation
    field(INP_ERR, DBF_INLINK) {
        prompt("Error Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(LERR, DBF_SHORT) {
        prompt("Error Status")
        special(SPC_NOMOD)
        interest(2)
    }

    # Home sensor — used for MSTA computation
    field(INP_HSEN, DBF_INLINK) {
        prompt("Home Sensor Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(HSEN, DBF_SHORT) {
        prompt("Home Sensor Active")
        special(SPC_NOMOD)
        interest(2)
    }

    # Homing in progress — used for MSTA computation
    field(INP_HMNG, DBF_INLINK) {
        prompt("Homing Input Link")
        promptgroup("40 - Input")
        interest(1)
    }
    field(HMNG, DBF_SHORT) {
        prompt("Homing In Progress")
        special(SPC_NOMOD)
        interest(2)
    }

    # Motor Status Word — computed from all status bools each cycle.
    # Bit layout follows motor record MSTA convention:
    #   bit 0  (0x0001) direction        NDIR
    #   bit 1  (0x0002) done             DMOV
    #   bit 2  (0x0004) plus limit       HLS
    #   bit 3  (0x0008) home switch      HSEN
    #   bit 5  (0x0020) minus limit      LLS
    #   bit 6  (0x0040) homed            ATHM
    #   bit 7  (0x0080) present          always 1
    #   bit 8  (0x0100) problem          LERR
    #   bit 9  (0x0200) moving           MOVN
    #   bit 11 (0x0800) comm error       link alarm
    #   bit 12 (0x1000) at home          ATHM
    #   bit 15 (0x8000) homing           HMNG
    field(MSTA, DBF_ULONG) {
        prompt("Motor Status Word")
        special(SPC_NOMOD)
        interest(1)
    }

    # -----------------------------------------------------------------------
    # Output fields
    # OUT_* — forward operator writes to PLC command PVs (PP)
    # RBK_* — read back PLC-confirmed value from _RBV PVs (CP)
    # -----------------------------------------------------------------------

    # Soft limits — map to NC axis position limits (NC:MaxPos:Goal /
    # NC:MinPos:Goal). Readback from NC:MaxPos:Val_RBV / NC:MinPos:Val_RBV.
    # LVIO is computed in process: 1 if RBV > HLM or RBV < LLM.
    field(HLM, DBF_DOUBLE) {
        prompt("High Soft Limit")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_HLM, DBF_OUTLINK) {
        prompt("High Soft Limit Output Link (NC:MaxPos:Goal)")
        promptgroup("50 - Output")
        interest(1)
    }

    field(LLM, DBF_DOUBLE) {
        prompt("Low Soft Limit")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_LLM, DBF_OUTLINK) {
        prompt("Low Soft Limit Output Link (NC:MinPos:Goal)")
        promptgroup("50 - Output")
        interest(1)
    }

    # Limit violation flag — computed from RBV vs HLM/LLM each cycle.
    # 1 if RBV > HLM or RBV < LLM, 0 otherwise.
    field(LVIO, DBF_SHORT) {
        prompt("Limit Violation")
        special(SPC_NOMOD)
        interest(1)
    }

    field(VAL, DBF_DOUBLE) {
        prompt("Desired Position")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
    }



    field(RBK_VAL,  DBF_INLINK) { prompt("VAL init readback")  special(SPC_NOMOD) interest(3) }
    field(RBK_VELO, DBF_INLINK) { prompt("VELO init readback") special(SPC_NOMOD) interest(3) }
    field(RBK_ACCS, DBF_INLINK) { prompt("ACCS init readback") special(SPC_NOMOD) interest(3) }
    field(RBK_CNEN, DBF_INLINK) { prompt("CNEN init readback") special(SPC_NOMOD) interest(3) }
    field(RBK_HLM,  DBF_INLINK) { prompt("HLM init readback")  special(SPC_NOMOD) interest(3) }
    field(RBK_LLM,  DBF_INLINK) { prompt("LLM init readback")  special(SPC_NOMOD) interest(3) }
    field(RBK_BDST, DBF_INLINK) { prompt("BDST init readback") special(SPC_NOMOD) interest(3) }
    field(OUT_VAL, DBF_OUTLINK) {
        prompt("Position Output Link")
        promptgroup("50 - Output")
        interest(1)
    }

    field(STOP, DBF_SHORT) {
        prompt("Stop")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_STOP, DBF_OUTLINK) {
        prompt("Stop Output Link")
        promptgroup("50 - Output")
        interest(1)
    }
    # No RBK_STOP — bHalt is a pure output driven by the SPMG state machine.
    # Reading it back via CP would create a scan loop.

    # HOMF — homes via low limit switch (eHomeMode=LOW_LIMIT=1)
    # HOMR — homes via high limit switch (eHomeMode=HIGH_LIMIT=2)
    # Both share OUT_HOMF (bHomeCmd) — direction set via OUT_HMOD (eHomeMode)
    field(HOMF, DBF_SHORT) {
        prompt("Home Forward (via low limit)")
        promptgroup("30 - Action")
        asl(ASL0)
        pp(TRUE)
        special(SPC_MOD)
        interest(1)
    }
    field(HOMR, DBF_SHORT) {
        prompt("Home Reverse (via high limit)")
        promptgroup("30 - Action")
        asl(ASL0)
        pp(TRUE)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_HOMF, DBF_OUTLINK) {
        prompt("Home Command Output Link (bHomeCmd)")
        promptgroup("50 - Output")
        interest(1)
    }
    field(OUT_HMOD, DBF_OUTLINK) {
        prompt("Home Mode Output Link (eHomeMode)")
        promptgroup("50 - Output")
        interest(1)
    }
    # RBK_HOMF intentionally omitted — bHomeCmd is a momentary pulse command.
    # The PLC clears it immediately. Reading it back would overwrite HOMF=0
    # on the next process cycle, causing repeated homing commands.

    field(VELO, DBF_DOUBLE) {
        prompt("Velocity (EGU/s)")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_VELO, DBF_OUTLINK) {
        prompt("Velocity Output Link")
        promptgroup("50 - Output")
        interest(1)
    }

    field(ACCS, DBF_DOUBLE) {
        prompt("Acceleration (EGU/s^2)")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_ACCS, DBF_OUTLINK) {
        prompt("Acceleration Output Link (fAcceleration)")
        promptgroup("50 - Output")
        interest(1)
    }
    field(OUT_DECS, DBF_OUTLINK) {
        prompt("Deceleration Output Link (fDeceleration)")
        promptgroup("50 - Output")
        interest(1)
    }

    field(CNEN, DBF_SHORT) {
        prompt("Enable Control")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_CNEN, DBF_OUTLINK) {
        prompt("Enable Control Output Link")
        promptgroup("50 - Output")
        interest(1)
    }

    # Backlash distance — maps to NC axis backlash parameter
    field(BDST, DBF_DOUBLE) {
        prompt("Backlash Distance (EGU)")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_BDST, DBF_OUTLINK) {
        prompt("Backlash Output Link (NC:Backlash:Goal)")
        promptgroup("50 - Output")
        interest(1)
    }

    # SPMG — Stop/Pause/Move/Go state machine owned by tcmotor.
    # Replaces FB_MotionSPMG in the PLC.
    #   0 = Stop  — assert bHalt, no resume
    #   1 = Pause — assert bHalt, position held
    #   2 = Move  — clear bHalt, trigger bMoveCmd, auto-revert to Pause on DMOV
    #   3 = Go    — clear bHalt, normal operation
    field(SPMG, DBF_MENU) {
        prompt("Stop/Pause/Move/Go")
        promptgroup("30 - Action")
        asl(ASL0)
        special(SPC_MOD)
        interest(1)
        menu(tcmotorSPMG)
        initial("3")
    }
    field(OUT_MCMD, DBF_OUTLINK) {
        prompt("Move Command Output Link (bMoveCmd)")
        promptgroup("50 - Output")
        interest(1)
    }

    # JOGF / JOGR — momentary jog commands.
    # On rising edge, VAL is written into the NC jog increment PV for the
    # corresponding direction, then the PLC jog command is pulsed.
    # The PLC clears bJogFwdCmd/bJogBwdCmd itself after seeing the command.
    # VAL is used as the jog increment so client screens need no extra field.
    field(JOGF, DBF_SHORT) {
        prompt("Jog Forward")
        promptgroup("30 - Action")
        asl(ASL0)
        pp(TRUE)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_JOGF, DBF_OUTLINK) {
        prompt("Jog Forward Output Link (bJogFwdCmd)")
        promptgroup("50 - Output")
        interest(1)
    }
    field(OUT_JIF, DBF_OUTLINK) {
        prompt("Jog Fwd Increment Output Link (NC:JogIncrFwd:Goal)")
        promptgroup("50 - Output")
        interest(1)
    }
    # RBK_JOGF intentionally omitted — bJogFwdCmd is a momentary pulse.

    field(JOGR, DBF_SHORT) {
        prompt("Jog Reverse")
        promptgroup("30 - Action")
        asl(ASL0)
        pp(TRUE)
        special(SPC_MOD)
        interest(1)
    }
    field(OUT_JOGR, DBF_OUTLINK) {
        prompt("Jog Reverse Output Link (bJogBwdCmd)")
        promptgroup("50 - Output")
        interest(1)
    }
    field(OUT_JIR, DBF_OUTLINK) {
        prompt("Jog Rev Increment Output Link (NC:JogIncrBwd:Goal)")
        promptgroup("50 - Output")
        interest(1)
    }
    # RBK_JOGR intentionally omitted — bJogBwdCmd is a momentary pulse.

    # -----------------------------------------------------------------------
    # Internal tracking fields — SPC_NOMOD, not accessible by CA clients
    # -----------------------------------------------------------------------
    field(LVAL, DBF_DOUBLE) {
        prompt("Last Val Monitored")
        special(SPC_NOMOD)
        interest(3)
    }
    field(LRBV, DBF_DOUBLE) {
        prompt("Last RBV Monitored")
        special(SPC_NOMOD)
        interest(3)
    }
    # Last-sent cache for output fields — suppress redundant ADS writes
    field(LOVL, DBF_DOUBLE) {
        prompt("Last Output Val Sent")
        special(SPC_NOMOD)
        interest(3)
    }
    field(LSTO, DBF_SHORT) {
        prompt("Last Stop Sent")
        special(SPC_NOMOD)
        interest(3)
    }
    field(BVALP, DBF_SHORT) {
        prompt("VAL Pending Move Flag")
        special(SPC_NOMOD)
        interest(3)
    }
    field(PDMOV, DBF_SHORT) {
        prompt("Previous DMOV for edge detection")
        special(SPC_NOMOD)
        interest(3)
    }
    field(BINIT, DBF_SHORT) {
        prompt("Initialization Complete Flag")
        special(SPC_NOMOD)
        interest(3)
    }
    field(BINIT2, DBF_SHORT) {
        prompt("Output Fields Initialized Flag")
        special(SPC_NOMOD)
        interest(3)
    }
    field(IDLY, DBF_DOUBLE) {
        prompt("Init Delay (seconds)")
        promptgroup("30 - Action")
        interest(2)
    }
    field(INITCB, DBF_NOACCESS) {
        prompt("Init Callback Structure")
        special(SPC_NOMOD)
        interest(4)
        extra("CALLBACK initcb")
    }
    field(LVEL, DBF_DOUBLE) {
        prompt("Last Velo Sent")
        special(SPC_NOMOD)
        interest(3)
    }
    field(LACS, DBF_DOUBLE) {
        prompt("Last Accs Sent")
        special(SPC_NOMOD)
        interest(3)
    }
    field(LCNE, DBF_SHORT) {
        prompt("Last CnEn Sent")
        special(SPC_NOMOD)
        interest(3)
    }
    field(LHLM, DBF_DOUBLE) {
        prompt("Last High Soft Limit Sent")
        special(SPC_NOMOD)
        interest(3)
    }
    field(LLLM, DBF_DOUBLE) {
        prompt("Last Low Soft Limit Sent")
        special(SPC_NOMOD)
        interest(3)
    }
    field(LBDS, DBF_DOUBLE) {
        prompt("Last Backlash Sent")
        special(SPC_NOMOD)
        interest(3)
    }
    # Last-posted values for monitor change detection — one per CA-visible field
    field(LDMOV, DBF_SHORT) { prompt("Last DMOV Posted") special(SPC_NOMOD) interest(3) }
    field(LMOVN, DBF_SHORT) { prompt("Last MOVN Posted") special(SPC_NOMOD) interest(3) }
    field(LHLS,  DBF_SHORT) { prompt("Last HLS Posted")  special(SPC_NOMOD) interest(3) }
    field(LLLS,  DBF_SHORT) { prompt("Last LLS Posted")  special(SPC_NOMOD) interest(3) }
    field(LATHM, DBF_SHORT) { prompt("Last ATHM Posted") special(SPC_NOMOD) interest(3) }
    field(LTDIR, DBF_SHORT) { prompt("Last TDIR Posted") special(SPC_NOMOD) interest(3) }
    field(LSTOP, DBF_SHORT) { prompt("Last STOP Posted") special(SPC_NOMOD) interest(3) }
    field(LSPMG, DBF_MENU) { prompt("Last SPMG Posted") special(SPC_NOMOD) interest(3) menu(tcmotorSPMG) }
    field(LLVIO, DBF_SHORT) { prompt("Last LVIO Posted") special(SPC_NOMOD) interest(3) }
    field(LJOGF, DBF_SHORT) { prompt("Last JOGF Posted") special(SPC_NOMOD) interest(3) }
    field(LJOGR, DBF_SHORT) { prompt("Last JOGR Posted") special(SPC_NOMOD) interest(3) }
    field(LJIF,  DBF_DOUBLE) { prompt("Last Jog Fwd Incr Sent") special(SPC_NOMOD) interest(3) }
    field(LJIR,  DBF_DOUBLE) { prompt("Last Jog Rev Incr Sent") special(SPC_NOMOD) interest(3) }
    field(LMSTA, DBF_ULONG) { prompt("Last MSTA Posted") special(SPC_NOMOD) interest(3) }
}
